{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run FastAPI backend",
			"type": "shell",
			"command": "python3",
			"options": {
				"cwd": "${workspaceFolder}/backend"
			},
			"args": [
				"-m",
				"uvicorn",
				"app.main:app",
				"--reload",
				"--host",
				"0.0.0.0",
				"--port",
				"8000"
			],
			"isBackground": true,
			"group": "build"
		}
	]
}